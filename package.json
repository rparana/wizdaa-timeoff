{
  "name": "wizdaa-timeoff",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:cov": "turbo run test:cov",
    "db:generate": "pnpm --filter @wizdaa/database db:generate",
    "db:migrate": "pnpm --filter @wizdaa/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @wizdaa/database db:migrate:deploy",
    "db:push": "pnpm --filter @wizdaa/database db:push",
    "db:reset": "pnpm --filter @wizdaa/database db:reset",
    "db:seed": "pnpm --filter @wizdaa/database db:seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
