# -----------------------------------------------------------------------------
# Copy to `.env` at the repo root (or export in your shell) for local dev.
# Docker Compose sets these inline for containers; this file documents shape.
# -----------------------------------------------------------------------------

# Prisma (SQLite). Example: file:./dev.db  |  file:/data/app.db (Docker volume)
DATABASE_URL="file:./dev.db"

# HTTP port for whichever Nest app you start (api defaults 3000, worker defaults 3002).
# Run API and worker in separate shells if both need custom ports.
PORT=3000

# Base URL of the HCM ingest mock (trailing slashes are stripped by the worker).
# Local: http://127.0.0.1:3001  |  Docker Compose service: http://hcm-mock:3001
HCM_MOCK_URL=http://127.0.0.1:3001

# Outbox → HCM HTTP client (apps/worker)
HCM_REQUEST_TIMEOUT_MS=5000
OUTBOX_BASE_DELAY_MS=1000
OUTBOX_MAX_BACKOFF_MS=900000
OUTBOX_MAX_JITTER_MS=500
