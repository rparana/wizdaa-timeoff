# =============================================================================
# Monorepo — copy to repo root `.env` for local development (optional).
# Docker Compose sets variables per service; this file documents all names.
# =============================================================================

# --- Prisma (API + worker) ---
# SQLite connection string. Both processes must point at the same file when
# API and worker run together locally. Examples:
#   file:./dev.db
#   file:/data/app.db   (Docker Compose named volume path inside containers)
DATABASE_URL="file:./dev.db"

# --- HTTP ports (each Nest app reads `PORT` in its own process) ---
#   apps/hcm-mock → default 3001
#   apps/api      → default 3000
#   apps/worker   → default 3002
# Use one `.env` per terminal / Compose service, or export before `pnpm dev`.
PORT=3000

# --- Worker → HCM ingest ---
# Base URL of the mock (trailing slash optional; worker strips it).
# Local: http://127.0.0.1:3001  |  Compose: http://hcm-mock:3001
HCM_MOCK_URL=http://127.0.0.1:3001

# POST timeout (ms) for outbox delivery HTTP calls.
HCM_REQUEST_TIMEOUT_MS=5000

# Outbox retry backoff (milliseconds).
OUTBOX_BASE_DELAY_MS=1000
OUTBOX_MAX_BACKOFF_MS=900000
OUTBOX_MAX_JITTER_MS=500

# Optional
# NODE_ENV=development
