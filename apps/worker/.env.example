# apps/worker — copy to `apps/worker/.env` or export before `pnpm dev`.
# Prisma reads DATABASE_URL; outbox consumer reads HCM_* and OUTBOX_*.

# SQLite (required). Same file as the API when running both locally.
DATABASE_URL="file:../../dev.db"

# HTTP port for the worker health server (default 3002).
PORT=3002

# Base URL of the HCM mock ingest API (default http://127.0.0.1:3001).
HCM_MOCK_URL=http://127.0.0.1:3001

# Timeout (ms) for each POST to `{HCM_MOCK_URL}/hcm/outbox/ingest`.
HCM_REQUEST_TIMEOUT_MS=5000

# Backoff between failed outbox delivery attempts.
OUTBOX_BASE_DELAY_MS=1000
OUTBOX_MAX_BACKOFF_MS=900000
OUTBOX_MAX_JITTER_MS=500

# Optional
# NODE_ENV=development
