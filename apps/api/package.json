{
  "name": "@wizdaa/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "echo \"no lint configured\"",
    "pretest": "pnpm --filter @wizdaa/database db:generate",
