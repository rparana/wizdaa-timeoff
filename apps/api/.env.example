# apps/api — copy to `apps/api/.env` or load from repo root `.env` if your tooling supports it.
# Prisma reads DATABASE_URL from the environment.

# SQLite (required). Must match the DB file used by the worker if both run locally.
DATABASE_URL="file:../../dev.db"

# HTTP port for the REST API (default 3000).
PORT=3000

# Optional: Node environment
# NODE_ENV=development
